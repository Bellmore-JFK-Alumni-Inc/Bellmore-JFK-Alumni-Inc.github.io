---
interface Props {
  title: string;
  description?: string;
  maxWidth?: string;
  bodyClass?: string;
}

const { title, description, maxWidth = 'max-w-4xl', bodyClass = 'p-0' } = Astro.props;
const hasFallback = Astro.slots.has('fallback');
---

<section class="py-8 md:py-10">
  <div class:list={['mx-auto w-full px-4 sm:px-6', maxWidth]}>
    <div
      class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm dark:border-slate-800 dark:bg-slate-900"
    >
      <div class="border-b border-slate-200 px-5 py-4 text-center dark:border-slate-800 sm:px-6 sm:text-left">
        <h2 class="text-2xl font-bold text-slate-900 dark:text-slate-100">{title}</h2>
        {description && <p class="mt-2 text-sm leading-6 text-slate-600 dark:text-slate-300">{description}</p>}
      </div>
      <div class:list={['bg-slate-50 dark:bg-slate-950', bodyClass]}>
        <slot />
      </div>
      {
        hasFallback && (
          <div class="border-t border-slate-200 bg-white px-5 py-4 text-center text-sm text-muted dark:border-slate-800 dark:bg-slate-900 sm:px-6">
            <slot name="fallback" />
          </div>
        )
      }
    </div>
  </div>
</section>
