---
import Layout from '~/layouts/PageLayout.astro';
import EmbedPanel from '~/components/common/EmbedPanel.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import Features2 from '~/components/widgets/Features2.astro';

const metadata = {
  title: 'Contact Us',
  description:
    'Get in touch with the Bellmore JFK Alumni Association. Email us, visit us at JFK High School, or connect on social media. Located at 3000 Bellmore Ave, Bellmore, NY.',
};
---

<Layout metadata={metadata}>
  <!-- HeroText Widget -->
  <HeroText tagline="Contact" title="Let's Connect!" />

  <!-- Contact Information -->
  <Features2
    title="Ways to Reach Us"
    subtitle="Feel free to contact us through any of these channels"
    items={[
      {
        title: 'General Inquiries',
        description: 'bellmorejfkalumni@gmail.com',
        icon: 'tabler:mail',
      },
      {
        title: 'Location',
        description: 'Bellmore JFK Alumni, Inc., John F Kennedy High School, 3000 Bellmore Ave, Bellmore, NY 11710',
        icon: 'tabler:map-pin',
      },
      {
        title: 'Social Media',
        description: 'Follow us on Facebook and Instagram for updates',
        icon: 'tabler:brand-facebook',
      },
    ]}
    columns={3}
  />

  <EmbedPanel
    title="Find Us"
    description="John F. Kennedy High School, 3000 Bellmore Ave, Bellmore, NY 11710"
    maxWidth="max-w-6xl"
  >
    <iframe
      src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2896.8701119180546!2d-73.53088101542988!3d40.65339256747961!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x89c27ecdb8961055%3A0x1f4671672dfdbbf0!2s3000%20Bellmore%20Ave%2C%20Bellmore%2C%20NY%2011710!5e1!3m2!1sen!2sus!4v1743876395563!5m2!1sen!2sus"
      title="Map showing JFK High School at 3000 Bellmore Ave, Bellmore, NY 11710"
      class="h-[450px] w-full border-0"
      allowfullscreen
      loading="lazy"
      referrerpolicy="no-referrer-when-downgrade"
    >
    </iframe>
  </EmbedPanel>
</Layout>
