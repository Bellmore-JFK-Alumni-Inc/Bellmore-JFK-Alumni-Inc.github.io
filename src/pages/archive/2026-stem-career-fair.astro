---
import Layout from '~/layouts/PageLayout.astro';
import EmbedPanel from '~/components/common/EmbedPanel.astro';
import HeroText from '~/components/widgets/HeroText.astro';

import careerFairPdf from '~/assets/documents/2026 STEM Career Fair.pdf';

const metadata = {
  title: '2026 STEM Career Fair (Archive)',
  description: 'Archived page for the 2026 STEM Career Fair held on April 21, 2026 at JFK High School in Bellmore, NY.',
  robots: { index: false, follow: false },
};

const quickFacts = [
  { label: 'Date', value: 'April 21, 2026' },
  { label: 'Time', value: '6:00 PM - 8:00 PM' },
  { label: 'Location', value: 'John F. Kennedy High School, Bellmore, NY' },
  { label: 'Audience', value: 'Students, families, alumni, and local employers' },
];
---

<Layout metadata={metadata}>
  <HeroText
    tagline="Archive"
    title="2026 STEM Career Fair"
    subtitle="This event has concluded. The participant guide and event details are preserved below for reference."
  />

  <EmbedPanel title="Event Guide" description="Event details and registration information." maxWidth="max-w-6xl">
    <iframe
      src={careerFairPdf}
      title="2026 STEM Career Fair Participant Guide"
      class="h-[900px] w-full border-0 md:h-[1100px]"
      loading="lazy"
    >
    </iframe>
    <p slot="fallback">
      If the embed does not load, <a
        href={careerFairPdf}
        target="_blank"
        rel="noopener noreferrer"
        class="text-blue-600 underline dark:text-blue-400">open the PDF directly</a
      >.
    </p>
  </EmbedPanel>

  <section class="pb-12 pt-2">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <div class="mb-6 text-center sm:text-left">
        <h2 class="text-2xl font-bold text-slate-900 dark:text-slate-100">Event Details</h2>
        <p class="mt-2 text-sm leading-6 text-slate-600 dark:text-slate-300">
          The 2026 STEM Career Fair connected students with professionals across engineering, healthcare, data, and
          tech.
        </p>
      </div>
      <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
        {
          quickFacts.map((fact) => (
            <div class="rounded-lg border border-slate-200 bg-slate-50 px-4 py-3 dark:border-slate-800 dark:bg-slate-950">
              <p class="text-xs uppercase tracking-wide text-slate-500 dark:text-slate-400">{fact.label}</p>
              <p class="mt-1 text-base font-semibold text-slate-900 dark:text-slate-100">{fact.value}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>
</Layout>
