---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';

import careerFairPdf from '~/assets/documents/2026 STEM Career Fair.pdf';

const metadata = {
  title: '2026 STEM Career Fair (Archive)',
  description: 'Archived page for the 2026 STEM Career Fair held on April 21, 2026 at JFK High School in Bellmore, NY.',
  robots: { index: false, follow: false },
};

const quickFacts = [
  { label: 'Date', value: 'April 21, 2026' },
  { label: 'Time', value: '6:00 PM - 8:00 PM' },
  { label: 'Location', value: 'John F. Kennedy High School, Bellmore, NY' },
  { label: 'Audience', value: 'Students, families, alumni, and local employers' },
];
---

<Layout metadata={metadata}>
  <HeroText
    tagline="Archive"
    title="2026 STEM Career Fair"
    subtitle="This event has concluded. The participant guide and event details are preserved below for reference."
  />

  <section class="py-12">
    <div class="container mx-auto px-4">
      <div class="grid gap-8 lg:grid-cols-5">
        <div class="lg:col-span-3">
          <div
            class="rounded-2xl bg-white/90 dark:bg-slate-900 shadow-xl border border-slate-200/80 dark:border-slate-800 overflow-hidden"
          >
            <div
              class="px-6 py-4 border-b border-slate-200 dark:border-slate-800 bg-gradient-to-r from-blue-600 via-cyan-500 to-emerald-400 text-white"
            >
              <h2 class="text-lg font-semibold">Event Guide</h2>
              <p class="text-sm text-white/90">Event details and registration information.</p>
            </div>
            <div class="w-full bg-slate-50 dark:bg-slate-950">
              <iframe
                src={careerFairPdf}
                title="2026 STEM Career Fair Participant Guide"
                class="w-full h-[900px] md:h-[1100px] border-0"
                loading="lazy"></iframe>
            </div>
            <div
              class="px-6 py-4 flex flex-col md:flex-row md:items-center md:justify-between gap-3 bg-slate-50/70 dark:bg-slate-950/60"
            >
              <a
                class="btn-primary inline-flex items-center justify-center gap-2"
                href={careerFairPdf}
                target="_blank"
                rel="noopener noreferrer"
              >
                Open in new tab
              </a>
              <p class="text-sm text-slate-600 dark:text-slate-300">
                If the embed does not load, use the button to open the PDF directly.
              </p>
            </div>
          </div>
        </div>

        <div class="lg:col-span-2">
          <div
            class="rounded-2xl bg-white/90 dark:bg-slate-900 shadow-lg border border-slate-200/80 dark:border-slate-800 h-full flex flex-col"
          >
            <div class="px-6 py-5 border-b border-slate-200 dark:border-slate-800">
              <h3 class="text-xl font-semibold text-slate-900 dark:text-slate-100">Event Details</h3>
              <p class="text-sm text-slate-600 dark:text-slate-300 mt-2">
                The 2026 STEM Career Fair connected students with professionals across engineering, healthcare, data, and tech.
              </p>
            </div>
            <div class="px-6 py-5 space-y-4">
              <div class="grid gap-3 sm:grid-cols-2">
                {
                  quickFacts.map((fact) => (
                    <div class="rounded-xl border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-950 px-4 py-3">
                      <p class="text-xs uppercase tracking-wide text-slate-500 dark:text-slate-400">{fact.label}</p>
                      <p class="text-base font-semibold text-slate-900 dark:text-slate-100">{fact.value}</p>
                    </div>
                  ))
                }
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
