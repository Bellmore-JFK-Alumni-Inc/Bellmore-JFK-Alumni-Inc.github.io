---
import Layout from '~/layouts/PageLayout.astro';
import EmbedPanel from '~/components/common/EmbedPanel.astro';
import HeroText from '~/components/widgets/HeroText.astro';

const metadata = {
  title: 'Member Registration',
  description:
    'Register to become a member of the Bellmore JFK Alumni Association. Fill out our membership form and join a community of JFK High School graduates.',
};
---

<Layout metadata={metadata}>
  <!-- HeroText Widget -->
  <HeroText
    tagline="Join"
    title="Register Now!"
    subtitle="Become a member of the Bellmore JFK Alumni Association. Fill out the registration form below and complete your membership payment."
  />

  <EmbedPanel
    title="Membership Registration Form"
    description="Complete the registration form here on the site."
    maxWidth="max-w-3xl"
  >
    <iframe
      src="https://docs.google.com/forms/d/e/1FAIpQLSeXFk8N_QPPvqTFWTGIMenRjFiEZ7ibScbJUHsXZ2BaeY9vUg/viewform?embedded=true"
      title="Bellmore JFK Alumni Membership Registration Form"
      class="h-[800px] w-full border-0"
      loading="lazy"
    >
      Loading registration form...
    </iframe>
    <p slot="fallback">
      If the form does not load, <a
        href="https://docs.google.com/forms/d/e/1FAIpQLSeXFk8N_QPPvqTFWTGIMenRjFiEZ7ibScbJUHsXZ2BaeY9vUg/viewform"
        target="_blank"
        rel="noopener noreferrer"
        class="text-blue-600 underline dark:text-blue-400">open the registration form directly</a
      >.
    </p>
  </EmbedPanel>

  <EmbedPanel
    title="Membership Payment"
    description="After completing the registration form above, submit your membership dues below."
    maxWidth="max-w-3xl"
    bodyClass="px-4 py-6"
  >
    <script is:inline src="https://donorbox.org/widget.js" data-paypal-express="false"></script>
    <iframe
      src="https://donorbox.org/embed/bellmore-jfk-alumni-inc?amount=20&show_content=true"
      title="Bellmore JFK Alumni Membership Payment"
      name="donorbox"
      data-allowpaymentrequest="allowpaymentrequest"
      seamless="seamless"
      style="max-width: 500px; min-width: 250px; max-height:none!important; border: none; overflow: hidden; margin: 0 auto; display: block;"
      height="900px"
      width="100%"
      allow="payment"
    >
    </iframe>
  </EmbedPanel>
</Layout>
